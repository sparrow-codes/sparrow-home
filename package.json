  "scripts": {
    "build:mobile": "npm run generate-fe-api && nx run sparrow-home-mobile:build:production",
    "build:server": "nx run server:build",
    "build:app": "npm run build:mobile && npm run build:server",
    "test:all": "npx nx run-many -t test",
    "generate-fe-api": "ng-openapi-gen -c ng-openapi-config.json",
    "start:local:env": "docker compose -f docker-local/docker-compose.yaml -p docker up -d",
    "run-dev-http-mobile": "http-server dist/apps/sparrow-home-mobile/browser -S -C cert.pem -o",
    "lint:all": "npx nx run-many -t eslint:lint"
  },
