{
  "name": "heat-pump-feature",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/fe/heat-pump/heat-pump-feature/src",
  "prefix": "lib",
  "projectType": "library",
  "tags": ["scope:fe-heat-pump-feature"],
  "targets": {
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/fe/heat-pump/heat-pump-feature/jest.config.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "storybook": {
      "executor": "@storybook/angular:start-storybook",
      "options": {
        "port": 4400,
        "configDir": "libs/fe/heat-pump/heat-pump-feature/.storybook",
        "browserTarget": "heat-pump-feature:build-storybook",
        "compodoc": false,
        "styles": [
          "@angular/material/prebuilt-themes/azure-blue.css",
          "apps/sparrow-home/src/styles.css"
        ]
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "build-storybook": {
      "executor": "@storybook/angular:build-storybook",
      "outputs": ["{options.outputDir}"],
      "options": {
        "outputDir": "dist/storybook/heat-pump-feature",
        "configDir": "libs/fe/heat-pump/heat-pump-feature/.storybook",
        "browserTarget": "heat-pump-feature:build-storybook",
        "compodoc": false
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    }
  }
}
