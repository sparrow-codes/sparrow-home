{
  "name": "alarm-feature",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/fe/alarm/alarm-feature/src",
  "prefix": "sp",
  "projectType": "library",
  "tags": ["scope: fe-alarm-feature"],
  "targets": {
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/fe/alarm/alarm-feature/jest.config.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "storybook": {
      "executor": "@storybook/angular:start-storybook",
      "compodoc": true,
      "port": 6006,
      "options": {
        "styles": [
          "@angular/material/prebuilt-themes/azure-blue.css",
          "apps/sparrow-home/src/styles.css"
        ]
      }
    }
  }
}
