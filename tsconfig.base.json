{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@sparrow-home/api": ["libs/fe/api/src/index.ts"],
      "@sparrow-home/core": ["libs/fe/core/src/index.ts"],
      "@sparrow-home/ui": ["libs/fe/ui/src/index.ts"],
      "@sparrow-server/auth": ["libs/nest/auth/src/index.ts"],
      "@sparrow-server/cloud": ["libs/nest/cloud/src/index.ts"],
      "@sparrow-server/entities": ["libs/nest/entities/src/index.ts"],
      "@sparrow-server/external-api": ["libs/nest/external-api/src/index.ts"],
      "@sparrow-server/init": ["libs/nest/init/src/index.ts"],
      "@sparrow-server/setup": ["libs/nest/setup/src/index.ts"],
      "@sparrow-server/shared": ["libs/nest/shared/src/index.ts"],
      "@sparrow-server/user": ["libs/nest/user/src/index.ts"],
      "@sparrow-server/tuya": ["libs/nest/tuya/src/index.ts"],
      "@sparrow-home/tuya-device-domain": ["libs/fe/tuya/tuya-device-domain/src/index.ts"],
      "@sparrow-home/tuya-device-feature": ["libs/fe/tuya/tuya-device-feature/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
