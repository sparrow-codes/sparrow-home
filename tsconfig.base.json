      "@sparrow-home/api": ["libs/fe/api/src/index.ts"],
      "@sparrow-home/automation-domain": ["libs/fe/automation/automation-domain/src/index.ts"],
      "@sparrow-home/automation-feature": ["libs/fe/automation/automation-feature/src/index.ts"],
      "@sparrow-home/core": ["libs/fe/core/src/index.ts"],
      "@sparrow-home/heat-pump-domain": ["libs/fe/heat-pump/heat-pump-domain/src/index.ts"],
      "@sparrow-home/heat-pump-feature": ["libs/fe/heat-pump/heat-pump-feature/src/index.ts"],
      "@sparrow-home/home-device-domain": ["libs/fe/home-device/home-device-domain/src/index.ts"],
      "@sparrow-home/home-device-feature": ["libs/fe/home-device/home-device-feature/src/index.ts"],
      "@sparrow-home/main-panel-domain": ["libs/fe/main-panel/main-panel-domain/src/index.ts"],
      "@sparrow-home/main-panel-feature": ["libs/fe/main-panel/main-panel-feature/src/index.ts"],
