mode='production'

# WARNING: The following database credentials are insecure defaults for example/demo use only.
#          These values MUST be changed for any production deployment.
dbUserName=sparrow
dbPassword=sparrow
dbName=sparrow_home

jwtSecret=MY_JWT_SECRET
jwtExpiry=2d

pushPublicKey=MY_PUSH_PUBLIC_KEY
pushPrivateKey=MY_PUSH_PRIVATE_KEY
pushAdminEmail=YOUR_EMAIL

zigbeeSerialPort=DEVICE #for example /dev/ttyUSB0
zigbeeSerialAdapter=YOUR_DEVICE_SERIAL_ADAPTER
zigbeeTimeZone=YOUR_TIME_ZONE #for example Europe/Warsaw
